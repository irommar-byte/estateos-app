{
  "expo": {
    "name": "EstateOS™",
    "displayName": "EstateOS™",
    "slug": "apple-style-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.estateos.app",
      "associatedDomains": [
        "webcredentials:estateos.pl"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "pl.estateos.app"
    },
    "extra": {
      "eas": {
        "projectId": "f60e36e2-c093-4e91-870b-e4580a058bc2"
      },
      "iapPakietPlusProductId": "pl.estateos.app.pakiet_plus_30d"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ],
      "react-native-iap"
    ]
  }
}
