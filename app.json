{
  "expo": {
    "name": "EstateOS™",
    "slug": "apple-style-app",
    "scheme": "estateos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.estateos.app",
      "associatedDomains": [
        "webcredentials:estateos.pl",
        "applinks:estateos.pl"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsUsageDescription": "EstateOS zapisuje w kalendarzu termin prezentacji nieruchomości, adres z ogłoszenia oraz przypomnienia (w tym czas wyjazdu).",
        "NSRemindersUsageDescription": "Opcjonalnie możemy powiązać termin z przypomnieniami systemowymi.",
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "pl.estateos.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "estateos.pl",
              "pathPrefix": "/o"
            },
            {
              "scheme": "https",
              "host": "estateos.pl",
              "pathPrefix": "/oferta"
            },
            {
              "scheme": "https",
              "host": "estateos.pl",
              "pathPrefix": "/offer"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "f60e36e2-c093-4e91-870b-e4580a058bc2"
      },
      "iapPakietPlusProductId": "pl.estateos.app.pakiet_plus_30d"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "EstateOS zapisuje w kalendarzu termin prezentacji, adres i przypomnienia o wyjeździe.",
          "remindersPermission": "Powiązanie z przypomnieniami systemowymi jest opcjonalne."
        }
      ],
      "react-native-iap",
      "expo-font"
    ]
  }
}
