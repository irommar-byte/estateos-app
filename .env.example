# --- Universal Links / App Links (produkcja na estateos.pl) ---
# Apple Developer → Membership → Team ID (10 znaków)
APPLE_TEAM_ID=

# Android: SHA-256 certyfikatu podpisu release (Google Play App Signing lub lokalny keystore).
# Kilka odcisków: rozdziel spacją lub przecinkiem.
ANDROID_SHA256_CERT_FINGERPRINT=

# Opcjonalnie (domyślnie jak w aplikacji Expo):
# IOS_BUNDLE_ID=pl.estateos.app
# ANDROID_PACKAGE_NAME=pl.estateos.app

# Publiczny adres serwisu (udostępnianie /o/{id}). Na produkcji ustaw np. https://estateos.pl
NEXT_PUBLIC_SITE_ORIGIN=https://estateos.pl
