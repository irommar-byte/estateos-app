{
  "name": "apple-style-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/purge-legacy-middleware.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start -p 3000",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 startOrReload ecosystem.config.cjs --env production",
    "pm2:save": "pm2 save",
    "deploy:prod": "npm ci && npm run build && npm run pm2:reload && npm run pm2:save",
    "deploy:server-only": "npm run build && npm run pm2:reload",
    "release:ship": "npm run check && npm run build && npm run pm2:reload && npm run pm2:save",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check",
    "smoke:postdeploy": "node scripts/postdeploy-smoke.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
