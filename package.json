    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.19.1",
    "multer": "^2.1.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "7.0.13",
    "openai": "^6.32.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
